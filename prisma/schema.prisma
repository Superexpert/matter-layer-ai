generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum WorkflowSource {
  builtIn
  custom
}

enum MatterDocumentSourceType {
  upload
}

enum WorkflowRunStatus {
  running
  completed
  failed
}

enum WorkflowRunStepFileSelectionSource {
  manual
  uploaded_during_step
}

enum MatterDocumentRepresentationType {
  MARKDOWN
}

enum MatterDocumentRepresentationStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum WorkflowExtractionRunStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL_FAILED
}

model Matter {
  id             String                  @id @default(cuid())
  name           String
  documents      MatterDocument[]
  workflowRuns   WorkflowRun[]
  extractionRuns WorkflowExtractionRun[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model User {
  id                String                @id @default(cuid())
  email             String                @unique
  name              String?
  image             String?
  role              UserRole              @default(USER)
  createdWorkflows  Workflow[]            @relation("WorkflowCreatedBy")
  updatedWorkflows  Workflow[]            @relation("WorkflowUpdatedBy")
  uploadedDocuments MatterDocument[]      @relation("MatterDocumentUploadedBy")
  selectedStepFiles WorkflowRunStepFile[] @relation("WorkflowRunStepFileSelectedBy")
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model AppSettings {
  id         String   @id @default("app")
  aiProvider String?
  aiModel    String?
  aiApiKey   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AiProviderConfig {
  id        String   @id @default(cuid())
  provider  String
  model     String
  apiKey    String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Workflow {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String
  definitionJson  Json
  source          WorkflowSource
  builtInVersion  Int?
  isSystem        Boolean        @default(false)
  isEnabled       Boolean        @default(true)
  createdByUserId String?
  updatedByUserId String?
  createdByUser   User?          @relation("WorkflowCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser   User?          @relation("WorkflowUpdatedBy", fields: [updatedByUserId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([source])
  @@index([isEnabled])
}

model MatterDocument {
  id                 String                         @id @default(cuid())
  matterId           String
  fileName           String
  mimeType           String
  size               Int
  sha256             String?
  storageProvider    String                         @default("database")
  storageKey         String?
  sourceType         MatterDocumentSourceType       @default(upload)
  uploadedByUserId   String
  matter             Matter                         @relation(fields: [matterId], references: [id], onDelete: Cascade)
  uploadedByUser     User                           @relation("MatterDocumentUploadedBy", fields: [uploadedByUserId], references: [id])
  content            MatterDocumentContent?
  representations    MatterDocumentRepresentation[]
  stepFileSelections WorkflowRunStepFile[]
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt

  @@index([matterId])
  @@index([uploadedByUserId])
  @@index([storageProvider])
}

model MatterDocumentContent {
  id               String         @id @default(cuid())
  matterDocumentId String         @unique
  bytes            Bytes
  createdAt        DateTime       @default(now())
  document         MatterDocument @relation(fields: [matterDocumentId], references: [id], onDelete: Cascade)
}

model MatterDocumentRepresentation {
  id               String                             @id @default(cuid())
  matterDocumentId String
  type             MatterDocumentRepresentationType
  status           MatterDocumentRepresentationStatus @default(PENDING)
  content          String?
  error            String?
  metadataJson     Json?
  document         MatterDocument                     @relation(fields: [matterDocumentId], references: [id], onDelete: Cascade)
  createdAt        DateTime                           @default(now())
  updatedAt        DateTime                           @updatedAt

  @@unique([matterDocumentId, type])
  @@index([matterDocumentId])
  @@index([status])
}

model WorkflowRun {
  id                   String                  @id
  matterId             String
  workflowDefinitionId String
  status               WorkflowRunStatus       @default(running)
  matter               Matter                  @relation(fields: [matterId], references: [id], onDelete: Cascade)
  extractionRuns       WorkflowExtractionRun[]
  stepOutputs          WorkflowRunStepOutput[]
  selectedFiles        WorkflowRunStepFile[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([matterId])
}

model WorkflowRunStepOutput {
  id            String      @id @default(cuid())
  workflowRunId String
  stepId        String
  outputJson    Json
  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([workflowRunId, stepId])
  @@index([workflowRunId])
}

model WorkflowExtractionRun {
  id                      String                      @id @default(cuid())
  workflowRunId           String
  stepId                  String
  matterId                String
  profile                 String
  representationType      String                      @default("MARKDOWN")
  status                  WorkflowExtractionRunStatus @default(PENDING)
  selectedDocumentIdsJson Json?
  metadataJson            Json?
  error                   String?
  startedAt               DateTime?
  completedAt             DateTime?
  workflowRun             WorkflowRun                 @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  matter                  Matter                      @relation(fields: [matterId], references: [id], onDelete: Cascade)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@index([workflowRunId])
  @@index([matterId])
  @@index([status])
}

model WorkflowRunStepFile {
  id               String                             @id @default(cuid())
  workflowRunId    String
  stepId           String
  matterDocumentId String
  selectedByUserId String
  selectedAt       DateTime                           @default(now())
  selectionSource  WorkflowRunStepFileSelectionSource
  workflowRun      WorkflowRun                        @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  matterDocument   MatterDocument                     @relation(fields: [matterDocumentId], references: [id], onDelete: Cascade)
  selectedByUser   User                               @relation("WorkflowRunStepFileSelectedBy", fields: [selectedByUserId], references: [id])

  @@unique([workflowRunId, stepId, matterDocumentId])
  @@index([matterDocumentId])
  @@index([selectedByUserId])
}
