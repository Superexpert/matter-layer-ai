AUTH_SECRET="paste-generated-secret-here"
AUTH_GOOGLE_ID="paste-client-id-here"
AUTH_GOOGLE_SECRET="paste-client-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# PostgreSQL database used by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/legal_os?schema=public"

# File storage defaults to database when unset.
# MATTER_FILE_STORAGE_PROVIDER="database"
# MATTER_FILE_MAX_UPLOAD_MB="25"
# MATTER_FILE_STORAGE_ROOT=".matter-layer/uploads"

# Enables detailed shared AI-provider request and response metadata.
# Applies to AI calls across all workflow steps.
# Disabled by default.
MATTER_LAYER_VERBOSE_AI_LOGGING=false

# Enables detailed Extraction workflow lifecycle and orchestration logs.
# Disabled by default.
MATTER_LAYER_VERBOSE_EXTRACTION_LOGGING=false

# Prints validated extracted fact fields and source excerpts to the server Terminal.
# WARNING: This may expose privileged or confidential matter content in logs.
# Disabled by default. Enable only during local diagnosis.
MATTER_LAYER_LOG_EXTRACTED_FACTS=false

# Prints deterministic collapsed fact fields, conflicts, and source excerpts to the server Terminal.
# WARNING: This may expose privileged or confidential matter content in logs.
# Disabled by default. Enable only during local diagnosis.
MATTER_LAYER_LOG_COLLAPSED_FACTS=false
